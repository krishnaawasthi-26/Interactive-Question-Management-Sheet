# ==============================
# Frontend Environment Variables
# File: .env
# ==============================

# Backend API base URL
VITE_API_BASE_URL="http://localhost:8080"

# Sync endpoint (can stay default in most cases)
VITE_SYNC_API_BASE_URL="/api/sync/outbox"

# Public sheet API (used for shared/public sheet fetch)
VITE_PUBLIC_SHEET_API_BASE_URL="https://node.codolio.com/api/question-tracker/v1/sheet/public/get-sheet-by-slug"

# Razorpay key id (publishable key, optional if backend returns keyId)
VITE_RAZORPAY_KEY_ID="rzp_test_your_key_id"

# Request timeout in milliseconds
VITE_API_TIMEOUT_MS="12000"

# Google client id fallback for frontend-only setup (optional)
VITE_APP_AUTH_GOOGLE_CLIENT_ID=""
# Backward compatible fallback name (optional)
VITE_GOOGLE_CLIENT_ID=""

# Web Push VAPID public key (optional; needed only for push subscription)
VITE_WEB_PUSH_PUBLIC_KEY=""
