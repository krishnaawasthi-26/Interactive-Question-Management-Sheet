# Backend Environment Variables
# File: backend/.env

# MongoDB
MONGODB_URI="mongodb://localhost:27017/iqms"

# Auth secret (use your own long random secret here)
APP_AUTH_SECRET="your_strong_auth_secret_here"

# Google OAuth (primary or list)
APP_AUTH_GOOGLE_CLIENT_ID="your_google_web_client_id_here"
# APP_AUTH_GOOGLE_CLIENT_IDS="your_google_web_client_id_here,another_google_web_client_id_here"

# OTP bypass key for testing only
APP_AUTH_OTP_BYPASS_KEY=""

# SMTP / OTP email settings
APP_MAIL_ENABLED="false"
APP_MAIL_HOST="smtp.gmail.com"
APP_MAIL_PORT="587"
APP_MAIL_USERNAME=""
APP_MAIL_PASSWORD=""
APP_MAIL_FROM=""
APP_MAIL_FROM_NAME="Create Sheets"
APP_MAIL_AUTH="true"
APP_MAIL_STARTTLS="true"

# Payments (Razorpay)
APP_PAYMENT_RAZORPAY_ENABLED="false"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
