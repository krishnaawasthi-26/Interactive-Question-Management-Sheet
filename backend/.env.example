# =============================
# Backend Environment Variables
# File: backend/.env
# =============================

# MongoDB
MONGODB_URI="mongodb://localhost:27017/iqms"

# Auth secret (MUST be long and random in production)
APP_AUTH_SECRET="replace-with-a-long-random-secret"

# Google OAuth (Web application client id)
APP_AUTH_GOOGLE_CLIENT_ID=""

# OTP bypass key for testing only (leave empty in production)
APP_AUTH_OTP_BYPASS_KEY=""

# SMTP / OTP email settings
APP_MAIL_ENABLED="false"
APP_MAIL_HOST="smtp.gmail.com"
APP_MAIL_PORT="587"
APP_MAIL_USERNAME=""
APP_MAIL_PASSWORD=""
APP_MAIL_FROM=""
APP_MAIL_FROM_NAME="IQMS"
APP_MAIL_AUTH="true"
APP_MAIL_STARTTLS="true"

# Payments (Razorpay)
APP_PAYMENT_RAZORPAY_ENABLED="false"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
